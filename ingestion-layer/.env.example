# =============================================================================
# GTA Hub — Ingestion Layer Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git (it's already in .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# REDDIT API (PRAW)
# Get these from: https://www.reddit.com/prefs/apps
# You need a Reddit account, then create a "script" type app.
# -----------------------------------------------------------------------------
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT="gta-hub-ingestion/0.1.0 by /u/your_username"

# -----------------------------------------------------------------------------
# GOOGLE GEMINI API (for AI extraction)
# Get your key from: https://aistudio.google.com/app/apikey
# Free tier: 1,500 requests/day at time of writing (much higher than Claude)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# YOUTUBE (no API key needed for transcript API, but useful for metadata)
# If you want video metadata (title, description), get a key from:
# https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
YOUTUBE_API_KEY=your_youtube_api_key_here_optional

# -----------------------------------------------------------------------------
# INGESTION SETTINGS
# These control behaviour without touching code.
# -----------------------------------------------------------------------------
# How many items to pull in "test mode" (cheap / fast)
TEST_MODE_LIMIT=5

# How many days back to pull on a one-off "catch-up" run
CATCHUP_DAYS=7

# Subreddits to monitor (comma-separated, no spaces)
SUBREDDITS="GTA5,GTAV,gtaonline"

# YouTube channel IDs or video IDs to monitor (comma-separated)
YOUTUBE_SOURCES="UCpB6JA15XSN6yEc0xB6sBkw"  # example: a GTA channel

# RSS feeds to parse (comma-separated)
RSS_FEEDS="https://www.rockstargames.com/newswire/rss"

# -----------------------------------------------------------------------------
# DEDUPLICATOR SETTINGS
# -----------------------------------------------------------------------------
# Similarity threshold (0.0 = nothing matches, 1.0 = exact match)
# Start at 0.85 and tune based on your test results.
DEDUP_THRESHOLD=0.85

# Which sentence-transformer model to use (runs locally, no API cost)
# all-MiniLM-L6-v2 is fast and good enough for English text.
EMBEDDING_MODEL="all-MiniLM-L6-v2"